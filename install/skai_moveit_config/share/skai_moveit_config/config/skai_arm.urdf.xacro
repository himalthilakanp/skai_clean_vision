<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="skai_arm">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import skai_arm urdf file -->
    <xacro:include filename="$(find arm_rviz)/urdf/skai_arm.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="skai_arm.ros2_control.xacro" />


    <xacro:skai_arm_ros2_control name="SKAIHardware" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
