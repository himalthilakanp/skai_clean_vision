<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="skai_arm_ros2_control" params="name initial_positions_file">
        <xacro:property name="initial_positions" value="${xacro.load_yaml(initial_positions_file)['initial_positions']}"/>

        <ros2_control name="${name}" type="system">
            <hardware>
                <!-- By default, set up controllers for simulation. This won't work on real hardware -->
                <plugin>mock_components/GenericSystem</plugin>
            </hardware>
            <joint name="ROT_1">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['ROT_1']}</param>
                </state_interface>
            </joint>
            <joint name="PITCH_1">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['PITCH_1']}</param>
                </state_interface>
            </joint>
            <joint name="PITCH_2">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['PITCH_2']}</param>
                </state_interface>
            </joint>
            <joint name="PITCH_3">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['PITCH_3']}</param>
                </state_interface>
            </joint>
            <joint name="ROT_2">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['ROT_2']}</param>
                </state_interface>
            </joint>
            <joint name="ROT_3">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['ROT_3']}</param>
                </state_interface>
            </joint>
            <joint name="FGR_1">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['FGR_1']}</param>
                </state_interface>
            </joint>
            <joint name="FGR_2">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['FGR_2']}</param>
                </state_interface>
            </joint>

        </ros2_control>
    </xacro:macro>
</robot>
